# Meta Ad Library API token — get from https://developers.facebook.com/
# Requires: Marketing API access + ID-verified Meta developer account
# Without this token, the app uses mock data from lib/mock-data.ts
META_AD_LIBRARY_TOKEN=

# Secret used to authorize the Vercel Cron endpoint
# Generate any random string and set the same value in Vercel project env vars
CRON_SECRET=
