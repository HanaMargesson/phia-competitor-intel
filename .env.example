# Meta Ad Library API token ГўВЂВ” get from https://developers.facebook.com/
# Requires: Marketing API access + ID-verified Meta developer account
# Without this token, the app uses mock data from lib/mock-data.ts
META_AD_LIBRARY_TOKEN=

# Secret used to authorize the Vercel Cron endpoint
# Generate any random string and set the same value in Vercel project env vars
CRON_SECRET=

# Higgsfield API key ГўВЂВ” for Step 2 (Creative Lab video generation)
# Get from https://cloud.higgsfield.ai/
# Without this key, /creative shows a Phia-branded mock preview per angle.
HIGGSFIELD_API_KEY=

# Meta Marketing API ГўВЂВ” for Step 1.6 (Phia's own ad insights at /insights)
# System User token generated in Business Manager ГўВ†В’ Users ГўВ†В’ System Users ГўВ†В’ phiaadsbot ГўВ†В’ Generate Token
# Scope: ads_read. Requires another business admin to approve the request.
# Without this token (or the ad account ID below), /insights renders mock data.
META_INSIGHTS_TOKEN=

# Phia Ads ad account ID (format: act_<NUMBER>) ГўВЂВ” find it in Ads Manager top-left dropdown.
META_AD_ACCOUNT_ID=
